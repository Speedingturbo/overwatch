<script setup>
import { ref, computed, watch, onMounted, onBeforeUnmount, nextTick } from 'vue'
import * as echarts from 'echarts'

const api = {
  get: (url) => fetch(url).then(r => r.json()),
  post: (url, data) => fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) }).then(r => r.json()),
  put: (url, data) => fetch(url, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) }).then(r => r.json()),
  del: (url) => fetch(url, { method: 'DELETE' }).then(r => r.json())
}

const activeTab = ref('progress')
const riskMenuExpanded = ref(false)
const riskSubTabs = ['risk', 'hazard', 'preshift', 'quality']

function toggleRiskMenu() {
  riskMenuExpanded.value = !riskMenuExpanded.value
}

function selectRiskSub(tab) {
  activeTab.value = tab
  if (tab === 'risk') backToRiskList()
  if (tab === 'quality') backToQualityList()
}

// --- 项目概况 ---
const ovName = ref('')
const ovContractor = ref('')
const ovLocation = ref('')
const overviewList = ref([])

async function loadOverview() {
  overviewList.value = await api.get('/api/overview')
}

async function addOverview() {
  const name = ovName.value.trim()
  const contractor = ovContractor.value.trim()
  const location = ovLocation.value.trim()
  if (!name || !contractor || !location) return
  const item = await api.post('/api/overview', { name, contractor, location })
  overviewList.value.push(item)
  ovName.value = ''
  ovContractor.value = ''
  ovLocation.value = ''
}

async function removeOverview(index) {
  const item = overviewList.value[index]
  await api.del('/api/overview/' + item.id)
  overviewList.value.splice(index, 1)
  // 联动删除（服务端已级联删除）
  const pIdx = projects.value.findIndex(p => p.name === item.name)
  if (pIdx !== -1) {
    projects.value.splice(pIdx, 1)
    nextTick(() => updateChart())
  }
  staffList.value = staffList.value.filter(s => s.project !== item.name)
  if (staffActiveProject.value === item.name) staffActiveProject.value = null
  supervisorList.value = supervisorList.value.filter(s => s.project !== item.name)
  if (supervisorActiveProject.value === item.name) supervisorActiveProject.value = null
  riskList.value = riskList.value.filter(r => r.project !== item.name)
  if (riskActiveProject.value === item.name) riskActiveProject.value = null
  qualityList.value = qualityList.value.filter(q => q.project !== item.name)
  if (qualityActiveProject.value === item.name) qualityActiveProject.value = null
}

// --- 编辑项目概况 ---
const editOverviewVisible = ref(false)
const editOverviewIndex = ref(-1)
const editOvName = ref('')
const editOvContractor = ref('')
const editOvLocation = ref('')

function openEditOverview(index) {
  const item = overviewList.value[index]
  editOverviewIndex.value = index
  editOvName.value = item.name
  editOvContractor.value = item.contractor
  editOvLocation.value = item.location
  editOverviewVisible.value = true
}

function closeEditOverview() {
  editOverviewVisible.value = false
}

async function saveEditOverview() {
  const name = editOvName.value.trim()
  const contractor = editOvContractor.value.trim()
  const location = editOvLocation.value.trim()
  if (!name || !contractor || !location) return
  const idx = editOverviewIndex.value
  const oldName = overviewList.value[idx].name
  const updated = await api.put('/api/overview/' + overviewList.value[idx].id, { name, contractor, location, oldName })
  overviewList.value[idx] = updated
  // 联动更新本地数据（服务端已级联更新）
  if (oldName !== name) {
    const p = projects.value.find(p => p.name === oldName)
    if (p) { p.name = name; nextTick(() => updateChart()) }
    staffList.value.forEach(s => { if (s.project === oldName) s.project = name })
    if (staffActiveProject.value === oldName) staffActiveProject.value = name
    supervisorList.value.forEach(s => { if (s.project === oldName) s.project = name })
    if (supervisorActiveProject.value === oldName) supervisorActiveProject.value = name
    riskList.value.forEach(r => { if (r.project === oldName) r.project = name })
    if (riskActiveProject.value === oldName) riskActiveProject.value = name
    qualityList.value.forEach(q => { if (q.project === oldName) q.project = name })
    if (qualityActiveProject.value === oldName) qualityActiveProject.value = name
  }
  editOverviewVisible.value = false
}

// --- 人员信息 ---
const staffName = ref('')
const staffPosition = ref('')
const staffPhone = ref('')
const staffIdCard = ref('')
const staffCert = ref('')
const staffList = ref([])
const staffActiveProject = ref(null)

async function loadStaff() {
  staffList.value = await api.get('/api/staff')
}

// 当前选中项目的人员列表
const staffForProject = computed(() => {
  if (!staffActiveProject.value) return []
  return staffList.value.filter(s => s.project === staffActiveProject.value)
})

// 各项目人员数量统计
const staffCountByProject = computed(() => {
  const map = {}
  staffList.value.forEach(s => {
    if (s.project) map[s.project] = (map[s.project] || 0) + 1
  })
  return map
})

// 各项目人员数量（饼状图数据）
const projectStaffStats = computed(() => {
  return overviewList.value.map(ov => ({
    name: ov.name,
    value: staffCountByProject.value[ov.name] || 0
  }))
})

let projectStaffChartInstance = null
const projectStaffChartRef = ref(null)

function ensureProjectStaffChart() {
  if (!projectStaffChartInstance && projectStaffChartRef.value) {
    projectStaffChartInstance = echarts.init(projectStaffChartRef.value)
  }
}

function updateProjectStaffChart() {
  ensureProjectStaffChart()
  if (!projectStaffChartInstance) return
  const option = {
    tooltip: { trigger: 'item', formatter: '{b}: {c}人 ({d}%)' },
    legend: { orient: 'vertical', right: 20, top: 'center', textStyle: { color: '#333' } },
    series: [{
      name: '项目人员分布',
      type: 'pie',
      radius: ['40%', '70%'],
      center: ['45%', '50%'],
      avoidLabelOverlap: true,
      itemStyle: { borderRadius: 6, borderColor: '#fff', borderWidth: 2 },
      label: {
        show: true,
        formatter: '{b}\n{c}人',
        color: '#333',
        textStyle: { color: '#333' }
      },
      data: projectStaffStats.value
    }]
  }
  projectStaffChartInstance.setOption(option, true)
  projectStaffChartInstance.resize()
}

function disposeProjectStaffChart() {
  if (projectStaffChartInstance) {
    projectStaffChartInstance.dispose()
    projectStaffChartInstance = null
  }
}

function enterStaffProject(projectName) {
  disposeProjectStaffChart()
  staffActiveProject.value = projectName
  nextTick(() => updateStaffChart())
}

function backToStaffList() {
  if (staffChartInstance) {
    staffChartInstance.dispose()
    staffChartInstance = null
  }
  staffActiveProject.value = null
  nextTick(() => updateProjectStaffChart())
}

async function addStaff() {
  const name = staffName.value.trim()
  const position = staffPosition.value.trim()
  const phone = staffPhone.value.trim()
  const idCard = staffIdCard.value.trim()
  const cert = staffCert.value.trim()
  if (!name || !position || !phone || !idCard) return
  const item = await api.post('/api/staff', { project: staffActiveProject.value, name, position, phone, idCard, cert })
  staffList.value.push(item)
  staffName.value = ''
  staffPosition.value = ''
  staffPhone.value = ''
  staffIdCard.value = ''
  staffCert.value = ''
  nextTick(() => updateStaffChart())
}

async function removeStaff(filteredIndex) {
  const item = staffForProject.value[filteredIndex]
  await api.del('/api/staff/' + item.id)
  const realIndex = staffList.value.findIndex(s => s.id === item.id)
  if (realIndex !== -1) staffList.value.splice(realIndex, 1)
  nextTick(() => updateStaffChart())
}

let staffChartInstance = null
const staffChartRef = ref(null)

const positionStats = computed(() => {
  const list = staffActiveProject.value ? staffForProject.value : staffList.value
  const map = {}
  list.forEach(s => {
    const pos = s.position || '未知'
    map[pos] = (map[pos] || 0) + 1
  })
  return Object.entries(map).map(([name, value]) => ({ name, value }))
})

function ensureStaffChart() {
  if (!staffChartInstance && staffChartRef.value) {
    staffChartInstance = echarts.init(staffChartRef.value)
  }
}

function updateStaffChart() {
  ensureStaffChart()
  if (!staffChartInstance) return
  const option = {
    tooltip: { trigger: 'item', formatter: '{b}: {c}人 ({d}%)' },
    legend: { orient: 'vertical', right: 20, top: 'center', textStyle: { color: '#333' } },
    series: [{
      name: '岗位分布',
      type: 'pie',
      radius: ['40%', '70%'],
      center: ['45%', '50%'],
      avoidLabelOverlap: true,
      itemStyle: { borderRadius: 6, borderColor: '#fff', borderWidth: 2 },
      label: {
        show: true,
        formatter: '{b}\n{c}人',
        color: '#333',
        textStyle: { color: '#333' }
      },
      data: positionStats.value
    }]
  }
  staffChartInstance.setOption(option, true)
  staffChartInstance.resize()
}

// --- 监理人员信息 ---
const supervisorName = ref('')
const supervisorPhone = ref('')
const supervisorList = ref([])
const supervisorActiveProject = ref(null)

async function loadSupervisors() {
  supervisorList.value = await api.get('/api/supervisors')
}

const supervisorForProject = computed(() => {
  if (!supervisorActiveProject.value) return []
  return supervisorList.value.filter(s => s.project === supervisorActiveProject.value)
})

const supervisorCountByProject = computed(() => {
  const map = {}
  supervisorList.value.forEach(s => {
    if (s.project) map[s.project] = (map[s.project] || 0) + 1
  })
  return map
})

function enterSupervisorProject(projectName) {
  supervisorActiveProject.value = projectName
}

function backToSupervisorList() {
  supervisorActiveProject.value = null
}

async function addSupervisor() {
  const name = supervisorName.value.trim()
  const phone = supervisorPhone.value.trim()
  if (!name || !phone) return
  const item = await api.post('/api/supervisors', { project: supervisorActiveProject.value, name, phone })
  supervisorList.value.push(item)
  supervisorName.value = ''
  supervisorPhone.value = ''
}

function getTodayStr() {
  const d = new Date()
  return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0')
}

function hasCheckedInToday(item) {
  return item.lastCheckIn === getTodayStr()
}

async function checkIn(filteredIndex) {
  const item = supervisorForProject.value[filteredIndex]
  const today = getTodayStr()
  if (item.lastCheckIn === today) return
  const updated = await api.put('/api/supervisors/' + item.id + '/checkin', { today })
  const realIndex = supervisorList.value.findIndex(s => s.id === item.id)
  if (realIndex !== -1) supervisorList.value[realIndex] = updated
}

async function removeSupervisor(filteredIndex) {
  const item = supervisorForProject.value[filteredIndex]
  await api.del('/api/supervisors/' + item.id)
  const realIndex = supervisorList.value.findIndex(s => s.id === item.id)
  if (realIndex !== -1) supervisorList.value.splice(realIndex, 1)
}

// --- 安全风险隐患 ---
const riskDesc = ref('')
const riskLevel = ref('')
const riskMeasure = ref('')
const riskDiscoverTime = ref('')
const riskDiscoverPlace = ref('')
const riskPhoto = ref('')
const riskList = ref([])
const riskActiveProject = ref(null)
const riskModalVisible = ref(false)
const riskFilterLevel = ref('')
const previewPhoto = ref('')
const riskEditIndex = ref(-1)
const editRiskModalVisible = ref(false)

async function loadRisks() {
  riskList.value = await api.get('/api/risks')
}

const riskForProject = computed(() => {
  if (!riskActiveProject.value) return []
  let list = riskList.value.filter(r => r.project === riskActiveProject.value)
  if (riskFilterLevel.value) {
    list = list.filter(r => r.level === riskFilterLevel.value)
  }
  return list
})

const riskCountByProject = computed(() => {
  const map = {}
  riskList.value.forEach(r => {
    if (r.project) map[r.project] = (map[r.project] || 0) + 1
  })
  return map
})

function enterRiskProject(projectName) {
  riskActiveProject.value = projectName
  riskFilterLevel.value = ''
}

function backToRiskList() {
  riskActiveProject.value = null
  riskFilterLevel.value = ''
  riskModalVisible.value = false
}

function openRiskModal() {
  riskDesc.value = ''
  riskDiscoverTime.value = getTodayStr()
  riskDiscoverPlace.value = ''
  riskLevel.value = ''
  riskPhoto.value = ''
  riskMeasure.value = ''
  riskModalVisible.value = true
}

function closeRiskModal() {
  riskModalVisible.value = false
}

function handleRiskPhoto(e) {
  const file = e.target.files[0]
  if (!file) return
  const reader = new FileReader()
  reader.onload = () => { riskPhoto.value = reader.result }
  reader.readAsDataURL(file)
}

async function addRisk() {
  const desc = riskDesc.value.trim()
  const level = riskLevel.value.trim()
  const measure = riskMeasure.value.trim()
  const discoverTime = riskDiscoverTime.value.trim()
  const discoverPlace = riskDiscoverPlace.value.trim()
  if (!desc || !level) return
  const item = await api.post('/api/risks', {
    project: riskActiveProject.value,
    desc,
    discoverTime: discoverTime || getTodayStr(),
    discoverPlace,
    level,
    photo: riskPhoto.value,
    measure
  })
  riskList.value.push(item)
  riskModalVisible.value = false
}

async function removeRisk(filteredIndex) {
  const item = riskForProject.value[filteredIndex]
  await api.del('/api/risks/' + item.id)
  const realIndex = riskList.value.findIndex(r => r.id === item.id)
  if (realIndex !== -1) riskList.value.splice(realIndex, 1)
}

function openEditRisk(filteredIndex) {
  const item = riskForProject.value[filteredIndex]
  riskEditIndex.value = riskList.value.indexOf(item)
  riskDesc.value = item.desc || ''
  riskDiscoverTime.value = item.discoverTime || item.date || ''
  riskDiscoverPlace.value = item.discoverPlace || ''
  riskLevel.value = item.level || ''
  riskPhoto.value = item.photo || ''
  riskMeasure.value = item.measure || ''
  editRiskModalVisible.value = true
}

function closeEditRisk() {
  editRiskModalVisible.value = false
}

async function saveEditRisk() {
  const idx = riskEditIndex.value
  if (idx < 0) return
  const desc = riskDesc.value.trim()
  const level = riskLevel.value.trim()
  if (!desc || !level) return
  const item = riskList.value[idx]
  const updated = await api.put('/api/risks/' + item.id, {
    desc,
    discoverTime: riskDiscoverTime.value.trim() || getTodayStr(),
    discoverPlace: riskDiscoverPlace.value.trim(),
    level,
    photo: riskPhoto.value,
    measure: riskMeasure.value.trim()
  })
  riskList.value[idx] = updated
  editRiskModalVisible.value = false
}

// --- 质量管理 ---
const qualityList = ref([])
const qualityActiveProject = ref(null)
const qualityModalVisible = ref(false)
const qualityRebarPhoto = ref('')
const qualityRebarContent = ref('')
const qualityWiringPhoto = ref('')
const qualityWiringContent = ref('')
const qualityEquipmentPhoto = ref('')
const qualityEquipmentContent = ref('')
const qualityPreviewPhoto = ref('')
const qualityEditIndex = ref(-1)
const editQualityModalVisible = ref(false)

async function loadQuality() {
  qualityList.value = await api.get('/api/quality')
}

const qualityForProject = computed(() => {
  if (!qualityActiveProject.value) return []
  return qualityList.value.filter(q => q.project === qualityActiveProject.value)
})

const qualityCountByProject = computed(() => {
  const map = {}
  qualityList.value.forEach(q => {
    if (q.project) map[q.project] = (map[q.project] || 0) + 1
  })
  return map
})

function enterQualityProject(projectName) {
  qualityActiveProject.value = projectName
}

function backToQualityList() {
  qualityActiveProject.value = null
  qualityModalVisible.value = false
}

function openQualityModal() {
  qualityEditIndex.value = -1
  qualityRebarPhoto.value = ''
  qualityRebarContent.value = ''
  qualityWiringPhoto.value = ''
  qualityWiringContent.value = ''
  qualityEquipmentPhoto.value = ''
  qualityEquipmentContent.value = ''
  qualityModalVisible.value = true
}

function closeQualityModal() {
  qualityModalVisible.value = false
}

function handleQualityPhoto(field, e) {
  const file = e.target.files[0]
  if (!file) return
  const reader = new FileReader()
  reader.onload = () => {
    if (field === 'rebar') qualityRebarPhoto.value = reader.result
    else if (field === 'wiring') qualityWiringPhoto.value = reader.result
    else if (field === 'equipment') qualityEquipmentPhoto.value = reader.result
  }
  reader.readAsDataURL(file)
}

async function addQuality() {
  const rebar = qualityRebarContent.value.trim()
  const wiring = qualityWiringContent.value.trim()
  const equipment = qualityEquipmentContent.value.trim()
  if (!rebar && !wiring && !equipment) return
  const item = await api.post('/api/quality', {
    project: qualityActiveProject.value,
    date: getTodayStr(),
    rebarPhoto: qualityRebarPhoto.value,
    rebarContent: rebar,
    wiringPhoto: qualityWiringPhoto.value,
    wiringContent: wiring,
    equipmentPhoto: qualityEquipmentPhoto.value,
    equipmentContent: equipment
  })
  qualityList.value.push(item)
  qualityModalVisible.value = false
}

function openEditQuality(filteredIndex) {
  const item = qualityForProject.value[filteredIndex]
  qualityEditIndex.value = qualityList.value.indexOf(item)
  qualityRebarPhoto.value = (item.rebar && item.rebar.photo) || ''
  qualityRebarContent.value = (item.rebar && item.rebar.content) || ''
  qualityWiringPhoto.value = (item.wiring && item.wiring.photo) || ''
  qualityWiringContent.value = (item.wiring && item.wiring.content) || ''
  qualityEquipmentPhoto.value = (item.equipment && item.equipment.photo) || ''
  qualityEquipmentContent.value = (item.equipment && item.equipment.content) || ''
  editQualityModalVisible.value = true
}

function closeEditQuality() {
  editQualityModalVisible.value = false
}

async function saveEditQuality() {
  const idx = qualityEditIndex.value
  if (idx < 0) return
  const rebar = qualityRebarContent.value.trim()
  const wiring = qualityWiringContent.value.trim()
  const equipment = qualityEquipmentContent.value.trim()
  if (!rebar && !wiring && !equipment) return
  const item = qualityList.value[idx]
  const updated = await api.put('/api/quality/' + item.id, {
    rebarPhoto: qualityRebarPhoto.value,
    rebarContent: rebar,
    wiringPhoto: qualityWiringPhoto.value,
    wiringContent: wiring,
    equipmentPhoto: qualityEquipmentPhoto.value,
    equipmentContent: equipment
  })
  qualityList.value[idx] = updated
  editQualityModalVisible.value = false
}

async function removeQuality(filteredIndex) {
  const item = qualityForProject.value[filteredIndex]
  await api.del('/api/quality/' + item.id)
  const realIndex = qualityList.value.findIndex(q => q.id === item.id)
  if (realIndex !== -1) qualityList.value.splice(realIndex, 1)
}

// --- 项目进度 ---
const selectedProject = ref('')
const projectProgress = ref('')
const projects = ref([])

// 可选项目列表：已在概况中登记但尚未填写进度的项目
const availableProjects = computed(() => {
  const usedNames = new Set(projects.value.map(p => p.name))
  return overviewList.value.filter(ov => !usedNames.has(ov.name))
})

let chartInstance = null
const chartRef = ref(null)

async function loadProjects() {
  projects.value = await api.get('/api/projects')
}

function ensureChart() {
  if (!chartInstance && chartRef.value) {
    chartInstance = echarts.init(chartRef.value)
  }
}

function updateChart() {
  ensureChart()
  if (!chartInstance) return
  const option = {
    tooltip: { trigger: 'axis' },
    xAxis: {
      type: 'category',
      data: projects.value.map((p) => p.name),
      axisLabel: { rotate: projects.value.length > 6 ? 30 : 0 }
    },
    yAxis: {
      type: 'value',
      name: '进度 (%)',
      min: 0,
      max: 100
    },
    series: [
      {
        name: '项目进度',
        type: 'bar',
        data: projects.value.map((p) => p.progress),
        barMaxWidth: 50,
        itemStyle: { color: '#3398DB' },
        label: { show: true, position: 'top', formatter: '{c}%' }
      }
    ],
    grid: { left: 60, right: 30, top: 40, bottom: 50 }
  }
  chartInstance.setOption(option, true)
  chartInstance.resize()
}

async function addProject() {
  const name = selectedProject.value
  const progress = Number(projectProgress.value)
  if (!name) return
  if (isNaN(progress) || progress < 0 || progress > 100) return
  const item = await api.post('/api/projects', { name, progress })
  projects.value.push(item)
  selectedProject.value = ''
  projectProgress.value = ''
  nextTick(() => updateChart())
}

async function removeProject(index) {
  const item = projects.value[index]
  await api.del('/api/projects/' + item.id)
  projects.value.splice(index, 1)
  nextTick(() => updateChart())
}

function handleResize() {
  chartInstance && chartInstance.resize()
  staffChartInstance && staffChartInstance.resize()
  projectStaffChartInstance && projectStaffChartInstance.resize()
}

watch(activeTab, (tab) => {
  if (tab === 'progress') {
    nextTick(() => {
      if (chartInstance) {
        chartInstance.resize()
      } else {
        updateChart()
      }
    })
  }
  if (tab === 'staff') {
    nextTick(() => {
      if (staffActiveProject.value) {
        if (staffChartInstance) {
          staffChartInstance.resize()
        } else {
          updateStaffChart()
        }
      } else {
        if (projectStaffChartInstance) {
          projectStaffChartInstance.resize()
        } else {
          updateProjectStaffChart()
        }
      }
    })
  }
})

onMounted(async () => {
  await Promise.all([
    loadOverview(),
    loadProjects(),
    loadStaff(),
    loadSupervisors(),
    loadRisks(),
    loadQuality()
  ])
  nextTick(() => updateChart())
  window.addEventListener('resize', handleResize)
})

onBeforeUnmount(() => {
  window.removeEventListener('resize', handleResize)
  if (chartInstance) {
    chartInstance.dispose()
    chartInstance = null
  }
  if (staffChartInstance) {
    staffChartInstance.dispose()
    staffChartInstance = null
  }
  disposeProjectStaffChart()
})
</script>

<template>
  <div class="page-layout">
    <aside class="sidebar">
      <ul class="sidebar-nav">
        <li
          :class="['sidebar-item', { active: activeTab === 'overview' }]"
          @click="activeTab = 'overview'"
        >项目概况</li>
        <li
          :class="['sidebar-item', { active: activeTab === 'progress' }]"
          @click="activeTab = 'progress'"
        >项目进度</li>
        <li
          :class="['sidebar-item', { active: activeTab === 'staff' }]"
          @click="activeTab = 'staff'; backToStaffList()"
        >人员信息</li>
        <li
          :class="['sidebar-item', { active: activeTab === 'supervisor' }]"
          @click="activeTab = 'supervisor'; backToSupervisorList()"
        >监理人员信息</li>
        <li
          :class="['sidebar-item', 'sidebar-parent', { active: riskSubTabs.includes(activeTab), expanded: riskMenuExpanded }]"
          @click="toggleRiskMenu()"
        >
          <span>安全风险隐患</span>
          <span class="arrow" :class="{ open: riskMenuExpanded }">▸</span>
        </li>
        <ul class="sidebar-sub" v-show="riskMenuExpanded">
          <li
            :class="['sidebar-sub-item', { active: activeTab === 'risk' }]"
            @click="selectRiskSub('risk')"
          >项目风险统计</li>
          <li
            :class="['sidebar-sub-item', { active: activeTab === 'hazard' }]"
            @click="selectRiskSub('hazard')"
          >危险源辨识清单</li>
          <li
            :class="['sidebar-sub-item', { active: activeTab === 'preshift' }]"
            @click="selectRiskSub('preshift')"
          >班前教育</li>
          <li
