          </div>
          <div class="workflow-step-row">
            <span
              v-for="ws in WORKFLOW_STEPS" :key="ws.step"
              class="wf-chip"
              :style="{ background: item.stepCounts[ws.step] > 0 ? ws.color + '33' : 'transparent', borderColor: item.stepCounts[ws.step] > 0 ? ws.color : 'rgba(255,255,255,0.15)', color: item.stepCounts[ws.step] > 0 ? ws.color : 'rgba(255,255,255,0.3)' }"
            >{{ ws.label }}&nbsp;{{ item.stepCounts[ws.step] }}</span>
          </div>
        </div>
      </div>
      <div v-else class="risk-summary-empty">暂无项目数据</div>
    </div>
    <div class="side-box workflow-box">
      <div class="risk-summary-header">
        <span>流程阶段汇总</span>
        <span class="risk-summary-total">共 {{ totalRiskCount }} 条</span>
      </div>
      <div v-if="totalRiskCount > 0" class="workflow-totals-content">
        <div v-for="ws in workflowStepTotals" :key="ws.step" class="workflow-total-item">
          <div class="workflow-total-left">
            <span class="wf-dot" :style="{ background: ws.color }"></span>
            <span class="workflow-total-label">{{ ws.label }}</span>
          </div>
          <div class="workflow-total-right">
            <div class="workflow-total-bar-track">
              <div
                class="workflow-total-bar-fill"
                :style="{ width: totalRiskCount > 0 ? (ws.count / totalRiskCount * 100) + '%' : '0%', background: ws.color }"
              ></div>
            </div>
            <span class="workflow-total-count" :style="{ color: ws.color }">{{ ws.count }} 条</span>
          </div>
        </div>
      </div>
      <div v-else class="risk-summary-empty">暂无风险数据</div>
    </div>
  </div>
  <header>
    <div class="china-map" v-html="chinaMapSvg"></div>
  </header>
</template>

