// --- 风险统计柱状图 ---
const riskLevels = ['低', '中', '高', '重大']
const riskLevelColors = { '低': '#27ae60', '中': '#f39c12', '高': '#e74c3c', '重大': '#8e44ad' }

const riskStatsByProjectAndLevel = computed(() => {
  const projectNames = overviewList.value.map(ov => ov.name)
  const map = {}
  projectNames.forEach(name => {
    map[name] = { '低': 0, '中': 0, '高': 0, '重大': 0 }
  })
  riskList.value.forEach(r => {
    if (r.project && map[r.project] && riskLevels.includes(r.level)) {
      map[r.project][r.level]++
    }
  })
  return { projectNames, map }
})

let riskBarChartInstance = null
const riskBarChartRef = ref(null)

function ensureRiskBarChart() {
  if (!riskBarChartInstance && riskBarChartRef.value) {
    riskBarChartInstance = echarts.init(riskBarChartRef.value)
  }
}

function updateRiskBarChart() {
  ensureRiskBarChart()
  if (!riskBarChartInstance) return
  const { projectNames, map } = riskStatsByProjectAndLevel.value
  const series = riskLevels.map(level => ({
    name: level,
    type: 'bar',
    stack: 'risk',
    barMaxWidth: 50,
    itemStyle: { color: riskLevelColors[level] },
    label: {
      show: true,
      position: 'inside',
      formatter: (params) => params.value > 0 ? params.value : '',
      color: '#fff',
      fontSize: 12
    },
    data: projectNames.map(name => map[name][level])
  }))
  const option = {
    tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' } },
    legend: { data: riskLevels, top: 0, textStyle: { color: '#333' } },
    xAxis: {
      type: 'category',
      data: projectNames,
      axisLabel: { rotate: projectNames.length > 6 ? 30 : 0 }
    },
    yAxis: { type: 'value', name: '数量', minInterval: 1 },
    series,
    grid: { left: 60, right: 30, top: 50, bottom: 50 }
  }
  riskBarChartInstance.setOption(option, true)
  riskBarChartInstance.resize()
}

function disposeRiskBarChart() {
  if (riskBarChartInstance) {
    riskBarChartInstance.dispose()
    riskBarChartInstance = null
  }
}

