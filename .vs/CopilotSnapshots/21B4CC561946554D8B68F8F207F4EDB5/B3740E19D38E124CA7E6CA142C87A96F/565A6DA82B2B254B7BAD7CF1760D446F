async function uploadFile() {
  const input = fileInputRef.value
  if (!input || !input.files.length) return
  const file = input.files[0]
  const formData = new FormData()
  formData.append('project', fileActiveProject.value)
  formData.append('category', fileCategory.value)
  formData.append('file', file)
  fileUploading.value = true
  try {
    const res = await fetch('/api/files', { method: 'POST', body: formData })
    const item = normalizeFileItem(await res.json())
    if (item.id) fileList.value.push(item)
    fileUploadModalVisible.value = false
  } finally {
    fileUploading.value = false
    input.value = ''
    fileCategory.value = '其他文件'
  }
}

function downloadFile(item) {
