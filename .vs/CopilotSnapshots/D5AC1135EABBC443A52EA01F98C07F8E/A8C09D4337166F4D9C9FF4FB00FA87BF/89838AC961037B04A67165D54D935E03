        </div>

        <form class="auth-form" @submit.prevent="handleRegister">
          <div class="auth-row">
            <div class="auth-field">
              <label>账号</label>
              <input v-model="form.username" type="text" maxlength="30" placeholder="请输入账号" autocomplete="username">
