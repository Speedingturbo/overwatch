  .side-box {
    width: 100%;
    height: 360px;
    background-color: rgba(51, 153, 255, 0.2);
    border: 1px solid rgba(59, 130, 246, 0.5);
    border-radius: 8px;
  }

/* 页面头部区域，用于放置中国地图 */
header {
  grid-column: 1 / -1;
  margin-top: 56px;
}

