const USERS_STORAGE_KEY = 'overwatch-users'
const AUTH_USER_STORAGE_KEY = 'overwatch-auth-user'

function readStorage(key, fallbackValue) {
  try {
    const rawValue = localStorage.getItem(key)
    return rawValue ? JSON.parse(rawValue) : fallbackValue
  } catch {
    return fallbackValue
  }
}

function writeStorage(key, value) {
  localStorage.setItem(key, JSON.stringify(value))
}

function sanitizeUser(user) {
  if (!user) return null

  return {
    id: user.id,
    username: user.username,
    realName: user.realName,
    phone: user.phone,
    createdAt: user.createdAt,
  }
}

export function getRegisteredUsers() {
  return readStorage(USERS_STORAGE_KEY, [])
}

export function getStoredAuthUser() {
  return readStorage(AUTH_USER_STORAGE_KEY, null)
}

export function isAuthenticated() {
  return Boolean(getStoredAuthUser())
}

export function registerUser({ username, realName, phone, password }) {
  const normalizedUsername = username.trim()
  const normalizedRealName = realName.trim()
  const normalizedPhone = phone.trim()
  const users = getRegisteredUsers()

  if (users.some(user => user.username === normalizedUsername)) {
    throw new Error('该账号已存在')
  }

  if (users.some(user => user.phone === normalizedPhone)) {
    throw new Error('该手机号已被注册')
  }

  const newUser = {
    id: Date.now(),
    username: normalizedUsername,
    realName: normalizedRealName,
    phone: normalizedPhone,
    password,
    createdAt: new Date().toISOString(),
  }

  writeStorage(USERS_STORAGE_KEY, [newUser, ...users])

  return sanitizeUser(newUser)
}

export function loginUser({ username, password }) {
  const normalizedUsername = username.trim()
  const users = getRegisteredUsers()
  const targetUser = users.find(user => user.username === normalizedUsername)

  if (!targetUser) {
    throw new Error('账号不存在，请先注册')
  }

  if (targetUser.password !== password) {
    throw new Error('密码错误')
  }

  const authUser = sanitizeUser(targetUser)
  writeStorage(AUTH_USER_STORAGE_KEY, authUser)

  return authUser
}

export function logoutUser() {
  localStorage.removeItem(AUTH_USER_STORAGE_KEY)
}
