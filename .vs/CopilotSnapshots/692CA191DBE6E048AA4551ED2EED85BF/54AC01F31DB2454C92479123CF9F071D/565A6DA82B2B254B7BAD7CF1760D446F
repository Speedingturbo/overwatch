<script setup>
import { ref, computed, watch, onMounted, onBeforeUnmount, nextTick } from 'vue'
import * as echarts from 'echarts'

const activeTab = ref('progress')

// --- 项目概况 ---
const ovName = ref('')
const ovContractor = ref('')
const ovLocation = ref('')
const overviewList = ref([])

function loadOverview() {
  try {
    const data = localStorage.getItem('overviewList')
    if (data) overviewList.value = JSON.parse(data)
  } catch { /* ignore */ }
}

function saveOverview() {
  localStorage.setItem('overviewList', JSON.stringify(overviewList.value))
}

function addOverview() {
  const name = ovName.value.trim()
  const contractor = ovContractor.value.trim()
  const location = ovLocation.value.trim()
  if (!name || !contractor || !location) return
  overviewList.value.push({ name, contractor, location })
  ovName.value = ''
  ovContractor.value = ''
  ovLocation.value = ''
  saveOverview()
}

function removeOverview(index) {
  const removed = overviewList.value.splice(index, 1)[0]
  saveOverview()
  // 联动删除对应的进度数据
  const pIdx = projects.value.findIndex(p => p.name === removed.name)
  if (pIdx !== -1) {
    projects.value.splice(pIdx, 1)
    saveProjects()
    nextTick(() => updateChart())
  }
}

// --- 人员信息 ---
const staffName = ref('')
const staffPosition = ref('')
const staffPhone = ref('')
const staffIdCard = ref('')
const staffCert = ref('')
const staffList = ref([])

function loadStaff() {
  try {
    const data = localStorage.getItem('staffList')
    if (data) staffList.value = JSON.parse(data)
  } catch { /* ignore */ }
}

function saveStaff() {
  localStorage.setItem('staffList', JSON.stringify(staffList.value))
}

function addStaff() {
  const name = staffName.value.trim()
  const position = staffPosition.value.trim()
  const phone = staffPhone.value.trim()
  const idCard = staffIdCard.value.trim()
  const cert = staffCert.value.trim()
  if (!name || !position || !phone || !idCard) return
  staffList.value.push({ name, position, phone, idCard, cert })
  staffName.value = ''
  staffPosition.value = ''
  staffPhone.value = ''
  staffIdCard.value = ''
  staffCert.value = ''
  saveStaff()
}

function removeStaff(index) {
  staffList.value.splice(index, 1)
  saveStaff()
}

// --- 项目进度 ---
const selectedProject = ref('')
const projectProgress = ref('')
const projects = ref([])

// 可选项目列表：已在概况中登记但尚未填写进度的项目
const availableProjects = computed(() => {
  const usedNames = new Set(projects.value.map(p => p.name))
  return overviewList.value.filter(ov => !usedNames.has(ov.name))
})

let chartInstance = null
const chartRef = ref(null)

function loadProjects() {
  try {
    const data = localStorage.getItem('projects')
    if (data) projects.value = JSON.parse(data)
  } catch { /* ignore */ }
}

function saveProjects() {
  localStorage.setItem('projects', JSON.stringify(projects.value))
}

function ensureChart() {
  if (!chartInstance && chartRef.value) {
    chartInstance = echarts.init(chartRef.value)
  }
}

function updateChart() {
  ensureChart()
  if (!chartInstance) return
  const option = {
    tooltip: { trigger: 'axis' },
    xAxis: {
      type: 'category',
      data: projects.value.map((p) => p.name),
      axisLabel: { rotate: projects.value.length > 6 ? 30 : 0 }
    },
    yAxis: {
      type: 'value',
      name: '进度 (%)',
      min: 0,
      max: 100
    },
    series: [
      {
        name: '项目进度',
        type: 'bar',
        data: projects.value.map((p) => p.progress),
        barMaxWidth: 50,
        itemStyle: { color: '#3398DB' },
        label: { show: true, position: 'top', formatter: '{c}%' }
      }
    ],
    grid: { left: 60, right: 30, top: 40, bottom: 50 }
  }
  chartInstance.setOption(option, true)
  chartInstance.resize()
}

function addProject() {
  const name = selectedProject.value
  const progress = Number(projectProgress.value)
  if (!name) return
  if (isNaN(progress) || progress < 0 || progress > 100) return
  projects.value.push({ name, progress })
  selectedProject.value = ''
  projectProgress.value = ''
  saveProjects()
  nextTick(() => updateChart())
}

function removeProject(index) {
  projects.value.splice(index, 1)
  saveProjects()
  nextTick(() => updateChart())
}

function handleResize() {
  chartInstance && chartInstance.resize()
}

watch(activeTab, (tab) => {
  if (tab === 'progress') {
    nextTick(() => {
      if (chartInstance) {
        chartInstance.resize()
      } else {
        updateChart()
      }
    })
  }
})

onMounted(() => {
  loadProjects()
  loadOverview()
  loadStaff()
  nextTick(() => updateChart())
  window.addEventListener('resize', handleResize)
})

onBeforeUnmount(() => {
  window.removeEventListener('resize', handleResize)
  if (chartInstance) {
    chartInstance.dispose()
    chartInstance = null
  }
})
</script>

